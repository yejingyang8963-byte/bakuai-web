---
// src/components/Hero.astro
import StarField from './StarField.astro';
import type { Lang } from '../lib/i18n';
import { loadContent } from '../lib/i18n';
export interface Props { lang: Lang }
const { lang } = Astro.props;
const c = loadContent(lang, 'hero');
// hero.yml fields:
// eyebrow, titleLine1, titleLine2 (italic), titleLine3, subtitle, cta, ctaSub, badges:[]
---
<section class="relative px-12 pt-15 pb-35 overflow-hidden" style="min-height:820px;">
  <StarField count={60} seed={11} />
  <div class="absolute pointer-events-none animate-breathe"
    style="right:-160px;top:-80px;width:880px;height:880px;opacity:.85;-webkit-mask-image:radial-gradient(circle at 50% 50%,black 35%,rgba(0,0,0,.6) 55%,transparent 78%);mask-image:radial-gradient(circle at 50% 50%,black 35%,rgba(0,0,0,.6) 55%,transparent 78%);">
    <img src="/illustrations/01-hero-moon.webp" alt=""
      style="width:100%;height:100%;object-fit:contain;filter:drop-shadow(0 0 120px rgba(255,208,128,.35)) saturate(1.05);" />
  </div>

  <!-- Drifting mist — four clouds (warm yellow / cool blue / cream / lavender) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none overflow-hidden" style="mix-blend-mode:screen;">
    <span class="hero-mist hero-mist-1" style="position:absolute;left:38%;top:12%;width:760px;height:520px;background:radial-gradient(ellipse 55% 50% at 50% 50%,rgba(255,200,120,.55) 0%,rgba(255,180,90,.28) 30%,rgba(255,160,80,.10) 55%,transparent 75%);filter:blur(28px);"/>
    <span class="hero-mist hero-mist-2" style="position:absolute;left:5%;top:48%;width:620px;height:440px;background:radial-gradient(ellipse 60% 55% at 50% 50%,rgba(140,170,255,.40) 0%,rgba(120,150,230,.18) 35%,rgba(100,130,200,.06) 60%,transparent 80%);filter:blur(32px);"/>
    <span class="hero-mist hero-mist-3" style="position:absolute;right:8%;top:58%;width:680px;height:480px;background:radial-gradient(ellipse 60% 55% at 50% 50%,rgba(255,235,200,.45) 0%,rgba(255,220,180,.20) 35%,rgba(255,200,160,.06) 60%,transparent 80%);filter:blur(36px);"/>
    <span class="hero-mist hero-mist-4" style="position:absolute;left:20%;top:78%;width:580px;height:360px;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(200,160,255,.30) 0%,rgba(170,140,230,.12) 40%,transparent 75%);filter:blur(40px);"/>
  </div>

  <!-- Bottom horizon fade -->
  <div aria-hidden="true" class="absolute pointer-events-none"
    style="left:0;right:0;bottom:0;height:220px;background:linear-gradient(180deg,transparent 0%,rgba(5,5,16,.6) 60%,#050510 100%);"/>

  <div class="relative" style="max-width:720px;">
    <div class="inline-flex items-center gap-2.5 mb-10 rounded-full"
      style="padding:6px 14px 6px 10px;background:rgba(255,208,128,.08);border:1px solid rgba(255,208,128,.2);">
      <span class="block rounded-full" style="width:6px;height:6px;background:#FFD080;box-shadow:0 0 8px #FFD080;"/>
      <span class="text-xs font-medium tracking-[0.06em]" style="color:#FFD080">{c.eyebrow}</span>
    </div>

    <h1 class="font-display font-light m-0 leading-[1.02] tracking-[-0.025em]" style="font-size:84px;color:#E8E0D4;">
      <span class="block">{c.titleLine1}</span>
      <span class="block italic" style="color:#FFD080">{c.titleLine2}</span>
      <span class="block">{c.titleLine3}</span>
    </h1>

    <p class="mt-8 text-[19px] leading-[1.55]" style="max-width:600px;color:rgba(232,224,212,.75)">{c.subtitle}</p>

    <div class="mt-11 flex items-center gap-5">
      <a href="https://apps.apple.com/app/id6762072650" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 rounded-2xl no-underline font-semibold"
        style="padding:18px 28px;font-size:16px;color:#050510;background:linear-gradient(180deg,#FFE0A0,#FFD080);box-shadow:0 12px 40px rgba(255,208,128,.25),inset 0 1px 0 rgba(255,255,255,.6);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
        </svg>
        {c.cta}
      </a>
      <span class="text-[13px] tracking-wide" style="color:rgba(255,255,255,.45)">{c.ctaSub}</span>
    </div>

    <div class="mt-14 flex flex-wrap gap-7">
      {c.badges?.map((b: string) => (
        <span class="flex items-center gap-2 text-[13px]" style="color:rgba(255,255,255,.55)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD080" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {b}
        </span>
      ))}
    </div>
  </div>
</section>
