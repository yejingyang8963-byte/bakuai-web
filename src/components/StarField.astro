---
// src/components/StarField.astro — pure-CSS twinkling star field.
// Stars are pre-generated at build time; no JS, no hydration cost.
export interface Props { count?: number; seed?: number }
const { count = 40, seed = 1 } = Astro.props;

// Deterministic PRNG so SSR & hydration agree
function rng(s: number) { let x = s; return () => { x = (x * 9301 + 49297) % 233280; return x / 233280; }; }
const r = rng(seed);
const stars = Array.from({ length: count }).map(() => {
  const big = r() < 0.18;
  return {
    x: r() * 100,
    y: r() * 100,
    size: big ? (r() < 0.5 ? 2 : 3) : 1,
    delay: r() * 6,
    variant: 1 + Math.floor(r() * 4),
    big,
  };
});
---
<div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
  {stars.map(s => (
    <span
      class={`absolute rounded-full twinkle-${s.variant}`}
      style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;background:${s.big?'#FFD080':'#FFF8E8'};${s.big?'box-shadow:0 0 4px rgba(255,208,128,.6);':''}animation-delay:${s.delay}s`}
    />
  ))}
</div>
