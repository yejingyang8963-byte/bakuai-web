---
interface Props {
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  cta: string;
  ctaSubtext: string;
  moonAlt: string;
}

const { titleLine1, titleLine2, subtitle, cta, ctaSubtext, moonAlt } = Astro.props;
---

<section class="hero">
  <div class="hero-moon">
    <img
      src="/illustrations/01-hero-moon.webp"
      alt={moonAlt}
      class="moon-img animate-breathe"
      width="1024"
      height="1024"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="hero-content">
    <h1 class="title">
      <span class="title-line">{titleLine1}</span>
      <span class="title-line">{titleLine2}</span>
    </h1>

    <p class="subtitle">{subtitle}</p>

    <button type="button" class="cta-button" disabled aria-disabled="true">
      {cta}
    </button>
    <p class="cta-subtext">{ctaSubtext}</p>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 20px 60px;
    position: relative;
    z-index: 2;
  }

  .hero-moon {
    flex: 0 0 auto;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 6vh;
    margin-bottom: 16px;
  }

  .moon-img {
    width: min(92vw, 520px);
    height: auto;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 0 60px rgba(255, 208, 128, 0.45))
            drop-shadow(0 0 120px rgba(255, 208, 128, 0.2));
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at center, black 45%, transparent 72%);
    mask-image: radial-gradient(ellipse 85% 85% at center, black 45%, transparent 72%);
    border-radius: 24px;
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .title {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    font-variation-settings: "opsz" 144;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 24px;
    text-shadow: 0 2px 24px rgba(5, 5, 16, 0.5);
  }

  .title-line {
    display: block;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 40px;
    max-width: 480px;
    text-shadow: 0 2px 16px rgba(5, 5, 16, 0.5);
  }

  .cta-button {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-muted);
    padding: 16px 40px;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: not-allowed;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .cta-subtext {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 16px 0 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 768px) {
    .moon-img {
      width: min(70vw, 620px);
    }
    .title {
      font-size: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-moon {
      padding-top: 4vh;
      margin-bottom: 8px;
    }
    .moon-img {
      width: min(55vw, 720px);
    }
    .title {
      font-size: 5.25rem;
    }
    .subtitle {
      font-size: 1.25rem;
      max-width: 560px;
    }
  }
</style>
