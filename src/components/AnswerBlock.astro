---
// src/components/AnswerBlock.astro — GEO answer card for LLM/search.
import type { Lang } from '../lib/i18n';
import { loadContent } from '../lib/i18n';
export interface Props { lang: Lang }
const { lang } = Astro.props;
const c = loadContent(lang, 'answer');
// answer.yml fields: label, question, answer, stats: [[label,value],...]
---
<section class="px-12" style="padding-top:60px;padding-bottom:60px;">
  <div class="mx-auto rounded-3xl"
    style="max-width:1100px;padding:48px 56px;background:rgba(255,255,255,.03);border:1px solid rgba(255,208,128,.15);backdrop-filter:blur(20px);">
    <div class="text-[11px] font-semibold uppercase mb-4 tracking-[0.18em]" style="color:#FFD080">{c.label}</div>
    <h2 class="font-display m-0 mb-5 font-normal" style="font-size:32px;color:#E8E0D4">{c.question}</h2>
    <p class="m-0 text-[17px]" style="line-height:1.65;max-width:880px;color:rgba(232,224,212,.82)">{c.answer}</p>

    <div class="mt-9 grid grid-cols-3" style="border-top:1px solid rgba(255,255,255,.08)">
      {c.stats?.map(([k, v]: [string, string], i: number) => (
        <div style={`padding:20px 24px;${i%3!==2 ? 'border-right:1px solid rgba(255,255,255,.06);':''}${i<3 ? 'border-bottom:1px solid rgba(255,255,255,.06);':''}`}>
          <div class="text-[11px] uppercase mb-1.5 tracking-[0.08em]" style="color:rgba(255,255,255,.45)">{k}</div>
          <div class="font-display font-medium" style="font-size:20px;color:#FFD080">{v}</div>
        </div>
      ))}
    </div>
  </div>
</section>
