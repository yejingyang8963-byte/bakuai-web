---
// src/components/StoryPreview.astro — animated story unfold (client island).
import StarField from './StarField.astro';
import type { Lang } from '../lib/i18n';
import { loadContent } from '../lib/i18n';
export interface Props { lang: Lang }
const { lang } = Astro.props;
const c = loadContent(lang, 'story-preview');
// story-preview.yml fields:
// eyebrow, sectionTitle, sub, wishLabel, wishes:[], model, status:[3], story:[5], footChip:[3], note
const storyJson = JSON.stringify(c.story);
const wishesJson = JSON.stringify(c.wishes);
const statusJson = JSON.stringify(c.status);
---
<section class="relative px-12" style="padding:100px 48px;">
  <StarField count={18} seed={31} />
  <div class="mx-auto" style="max-width:1200px;">
    <div class="text-[11px] font-semibold uppercase mb-4 tracking-[0.18em]" style="color:#FFD080">{c.eyebrow}</div>
    <h2 class="font-display font-light m-0 mb-4" style="font-size:58px;line-height:1.05;letter-spacing:-0.02em;color:#E8E0D4">{c.sectionTitle}</h2>
    <p class="text-[18px] m-0 mb-14" style="max-width:640px;color:rgba(232,224,212,.65)">{c.sub}</p>

    <div class="grid overflow-hidden rounded-[26px]"
      style="grid-template-columns:380px 1fr;background:rgba(255,255,255,.025);border:1px solid rgba(255,208,128,.18);backdrop-filter:blur(20px);">
      <!-- Left: wish picker -->
      <div style="padding:36px 32px;border-right:1px solid rgba(255,255,255,.08);background:rgba(5,5,16,.4)">
        <div class="text-[11px] font-semibold uppercase mb-[18px] tracking-[0.14em]" style="color:rgba(255,208,128,.9)">{c.wishLabel}</div>
        <div class="flex flex-col gap-2 mb-8" data-wish-list>
          {c.wishes?.map((w: string, i: number) => (
            <button data-wish-idx={i} type="button"
              class="text-left rounded-xl font-display italic text-[15px] cursor-pointer transition-all"
              style={`padding:14px 16px;line-height:1.4;${i===0
                ? 'background:rgba(255,208,128,.14);border:1px solid rgba(255,208,128,.5);color:#FFE9BE;'
                : 'background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);color:rgba(232,224,212,.75);'}`}>
              {w}
            </button>
          ))}
        </div>
        <div class="rounded-xl" style="padding:16px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06)">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="rounded-full" style="width:8px;height:8px;background:#7CEFA8;box-shadow:0 0 8px #7CEFA8;"/>
            <span class="text-xs font-medium" style="color:rgba(232,224,212,.75)">{c.model}</span>
          </div>
          <p class="m-0 text-[11px]" style="line-height:1.5;color:rgba(232,224,212,.5)">{c.note}</p>
        </div>
      </div>

      <!-- Right: story area -->
      <div class="relative" style="padding:36px 44px;min-height:440px;background:radial-gradient(ellipse at 80% 0%,rgba(255,208,128,.08) 0%,transparent 60%);">
        <div class="flex items-center gap-3.5 mb-7">
          <div class="flex gap-1" data-dots>
            <span class="rounded-full" style="width:6px;height:6px;background:#FFD080;animation:bounceDot 1.2s ease-in-out infinite;animation-delay:0s"/>
            <span class="rounded-full" style="width:6px;height:6px;background:rgba(255,255,255,.15);"/>
            <span class="rounded-full" style="width:6px;height:6px;background:rgba(255,255,255,.15);"/>
          </div>
          <span class="text-xs uppercase font-medium tracking-[0.1em]" style="color:rgba(255,208,128,.85)" data-status>{c.status[0]}</span>
          <span class="flex-1"/>
          <span class="flex items-center gap-[3px]" style="height:20px" data-wave>
            {[6,11,16,9,14,8,13,10,6].map(h => (
              <span class="rounded-[1px]" style={`width:2px;height:${h}px;background:rgba(255,208,128,.55);opacity:.25`} />
            ))}
          </span>
        </div>

        <div class="font-display font-light text-[22px]" style="line-height:1.65;color:#E8E0D4;min-height:220px" data-story />

        <div class="flex flex-wrap gap-2.5 mt-9">
          {c.footChip?.map((chip: string) => (
            <span class="inline-flex items-center gap-1.5 rounded-full text-[11px] font-medium tracking-wider"
              style="padding:6px 12px;background:rgba(255,208,128,.06);border:1px solid rgba(255,208,128,.2);color:#FFD080">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {chip}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes bounceDot { 0%,80%,100% { transform: scale(.6); opacity:.4 } 40% { transform: scale(1); opacity:1 } }
  @keyframes pulseWave { 0%,100% { opacity:.35 } 50% { opacity:1 } }
</style>

<script is:inline define:vars={{ stories: storyJson, wishes: wishesJson, statuses: statusJson }}>
  (() => {
    const STORIES = JSON.parse(stories);
    const STATUSES = JSON.parse(statuses);
    const root = document.currentScript.previousElementSibling
      ? document.querySelector('section [data-story]')?.closest('section')
      : null;
    if (!root) return;
    const buttons = root.querySelectorAll('[data-wish-idx]');
    const storyEl = root.querySelector('[data-story]');
    const statusEl = root.querySelector('[data-status]');
    const dots = root.querySelectorAll('[data-dots] > span');
    const waveBars = root.querySelectorAll('[data-wave] > span');

    let timers = [];
    function clearTimers() { timers.forEach(t => clearTimeout(t) || clearInterval(t)); timers = []; }

    function setDot(active) {
      dots.forEach((d, i) => {
        d.style.background = i === active ? '#FFD080' : 'rgba(255,255,255,.15)';
        d.style.animation = (i === active && active < 2) ? 'bounceDot 1.2s ease-in-out infinite' : 'none';
      });
    }
    function setWave(on) {
      waveBars.forEach((b, i) => {
        b.style.opacity = on ? 1 : .25;
        b.style.animation = on ? `pulseWave ${0.7 + i*0.08}s ease-in-out infinite` : 'none';
      });
    }
    function activate(idx) {
      buttons.forEach((b, i) => {
        if (i === idx) {
          b.style.background = 'rgba(255,208,128,.14)';
          b.style.border = '1px solid rgba(255,208,128,.5)';
          b.style.color = '#FFE9BE';
        } else {
          b.style.background = 'rgba(255,255,255,.03)';
          b.style.border = '1px solid rgba(255,255,255,.06)';
          b.style.color = 'rgba(232,224,212,.75)';
        }
      });
    }
    function play(wishIdx) {
      clearTimers();
      activate(wishIdx);
      const story = STORIES[wishIdx % STORIES.length] || STORIES[0];
      const sentences = Array.isArray(story) ? story : STORIES;
      const fullText = sentences.join(' ');

      // phase 0: listening
      setDot(0); setWave(false);
      statusEl.textContent = STATUSES[0];
      storyEl.innerHTML = '';

      timers.push(setTimeout(() => { setDot(1); statusEl.textContent = STATUSES[1]; }, 900));
      timers.push(setTimeout(() => { setDot(2); setWave(true); statusEl.textContent = STATUSES[2]; }, 2000));

      let i = 0;
      const id = setInterval(() => {
        i += 2;
        if (i >= fullText.length) { i = fullText.length; clearInterval(id); }
        // sentence highlighting
        let acc = 0;
        const html = sentences.map((s, si) => {
          const start = acc, end = acc + s.length + 1;
          acc = end;
          if (i <= start) return `<span style="opacity:.15;color:rgba(232,224,212,.35)">${s} </span>`;
          const visible = i >= end - 1 ? s : s.slice(0, i - start);
          const isCurrent = i < end;
          const color = isCurrent ? '#FFE9BE' : '#E8E0D4';
          const cursor = isCurrent
            ? '<span style="display:inline-block;width:2px;height:.9em;background:#FFD080;margin-left:2px;vertical-align:middle;animation:pulseWave .9s ease-in-out infinite"></span>'
            : '';
          return `<span style="color:${color}">${visible}${cursor} </span>`;
        }).join('');
        storyEl.innerHTML = html;
      }, 32);
      timers.push(id);
    }

    buttons.forEach((b, i) => b.addEventListener('click', () => play(i)));
    // autoplay first when scrolled into view
    const io = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) { play(0); io.disconnect(); }
    }, { threshold: 0.3 });
    io.observe(root);
  })();
</script>
