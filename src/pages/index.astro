---
// src/pages/index.astro — English (default locale, unprefixed)
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import AnswerBlock from '../components/AnswerBlock.astro';
import Why from '../components/Why.astro';
import HowItWorks from '../components/HowItWorks.astro';
import StoryPreview from '../components/StoryPreview.astro';
import Inside from '../components/Inside.astro';
import Comparison from '../components/Comparison.astro';
import Founder from '../components/Founder.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const lang = 'en' as const;
---
<BaseLayout lang={lang}>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <AnswerBlock lang={lang} />
  <Why lang={lang} />
  <HowItWorks lang={lang} />
  <StoryPreview lang={lang} />
  <Inside lang={lang} />
  <Comparison lang={lang} />
  <Founder lang={lang} />
  <FAQ lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
