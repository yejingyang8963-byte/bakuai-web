---
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  currentLang: 'en' | 'zh';
  panoramaIllustration: string;
  panoramaIllustrationAlt: string;
  brand: string;
  tagline: string;
  linkPrivacy: string;
  linkTerms: string;
  linkEmail: string;
  copyright: string;
  langSwitcherEN: string;
  langSwitcherZH: string;
  privacyHref: string;
  termsHref: string;
}

const {
  currentLang,
  panoramaIllustration,
  panoramaIllustrationAlt,
  brand,
  tagline,
  linkPrivacy,
  linkTerms,
  linkEmail,
  copyright,
  langSwitcherEN,
  langSwitcherZH,
  privacyHref,
  termsHref,
} = Astro.props;
---

<footer class="footer">
  <div class="footer-panorama">
    <img
      src={`/illustrations/${panoramaIllustration}.webp`}
      alt={panoramaIllustrationAlt}
      width="1024"
      height="512"
      loading="lazy"
    />
  </div>

  <div class="footer-inner">
    <div class="footer-brand">
      <p class="brand-name">{brand}</p>
      <p class="brand-tagline">{tagline}</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={privacyHref}>{linkPrivacy}</a>
      <span class="link-divider" aria-hidden="true">·</span>
      <a href={termsHref}>{linkTerms}</a>
      <span class="link-divider" aria-hidden="true">·</span>
      <a href="mailto:Metaphoria1688@gmail.com">{linkEmail}</a>
    </nav>

    <p class="footer-copyright">{copyright}</p>

    <LangSwitcher currentLang={currentLang} enLabel={langSwitcherEN} zhLabel={langSwitcherZH} />
  </div>
</footer>

<style>
  .footer {
    margin-top: 96px;
    position: relative;
    z-index: 2;
  }

  .footer-panorama {
    width: 100%;
    overflow: hidden;
  }

  .footer-panorama img {
    width: 100%;
    height: auto;
    display: block;
  }

  .footer-inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 48px 20px 64px;
    text-align: center;
  }

  .footer-brand {
    margin-bottom: 32px;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .brand-tagline {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 4px 0 0;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .link-divider {
    color: var(--color-text-muted);
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 24px;
  }
</style>
