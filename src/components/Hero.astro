---
interface Props {
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  cta: string;
  ctaSubtext: string;
  moonAlt: string;
}

const { titleLine1, titleLine2, subtitle, cta, ctaSubtext, moonAlt } = Astro.props;
---

<section class="hero">
  <img
    src="/illustrations/01-hero-moon.webp"
    alt={moonAlt}
    class="moon-bg animate-breathe"
    width="1024"
    height="1024"
    loading="eager"
    fetchpriority="high"
  />

  <div class="hero-content">
    <h1 class="title">
      <span class="title-line">{titleLine1}</span>
      <span class="title-line">{titleLine2}</span>
    </h1>

    <p class="subtitle">{subtitle}</p>

    <button type="button" class="cta-button" disabled aria-disabled="true">
      {cta}
    </button>
    <p class="cta-subtext">{ctaSubtext}</p>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 60px 20px 80px;
    text-align: center;
    overflow: hidden;
  }

  .moon-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    width: min(120vw, 720px);
    height: auto;
    max-width: none;
    object-fit: contain;
    pointer-events: none;
    z-index: 1;
    filter: drop-shadow(0 0 80px rgba(255, 208, 128, 0.35));
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin: 0 auto;
    padding-top: 50vh;
  }

  .title {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 800;
    font-variation-settings: "opsz" 144;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 24px;
    text-shadow: 0 2px 24px rgba(5, 5, 16, 0.6);
  }

  .title-line {
    display: block;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 48px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    text-shadow: 0 2px 16px rgba(5, 5, 16, 0.6);
  }

  .cta-button {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-muted);
    padding: 16px 40px;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: not-allowed;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .cta-subtext {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 16px 0 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 768px) {
    .moon-bg {
      width: min(85vw, 900px);
      transform: translate(-50%, -60%);
    }
    .hero-content {
      padding-top: 55vh;
    }
  }

  @media (min-width: 1024px) {
    .moon-bg {
      width: min(70vw, 1100px);
      transform: translate(-50%, -58%);
    }
    .title {
      font-size: 5.25rem;
    }
    .subtitle {
      font-size: 1.25rem;
      max-width: 560px;
    }
  }
</style>
