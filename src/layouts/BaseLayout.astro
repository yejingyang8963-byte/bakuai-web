---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import type { Lang } from '../lib/i18n';
import { loadContent } from '../lib/i18n';
export interface Props { lang: Lang }
const { lang } = Astro.props;
const meta = loadContent(lang, 'meta');
// meta.yml: htmlLang, title, description, keywords, ogTitle, ogDescription
const ldApp = {
  '@context':'https://schema.org','@type':'MobileApplication',
  name:'Baku AI', operatingSystem:'iOS 17+', applicationCategory:'KidsApplication',
  description: meta.description,
  offers:{ '@type':'Offer', price:'19.99', priceCurrency:'USD' },
  author:{ '@type':'Person', name:'Jingyang Ye' },
  featureList:['100% offline after first launch','Gemma 4 on-device AI','English + Simplified Chinese + Spanish','12-language safety filter','Zero data collection','No accounts, no subscriptions'],
};
const faq = loadContent(lang, 'faq');
const ldFaq = {
  '@context':'https://schema.org','@type':'FAQPage',
  mainEntity: (faq.items || []).map((it: any) => ({ '@type':'Question', name: it.question, acceptedAnswer: { '@type':'Answer', text: it.answer } })),
};
---
<!doctype html>
<html lang={meta.htmlLang || lang}>
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{meta.title}</title>
  <meta name="description" content={meta.description}/>
  {meta.keywords && <meta name="keywords" content={meta.keywords}/>}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="apple-touch-icon" href="/apple-touch-icon.png"/>

  <meta property="og:title"       content={meta.ogTitle || meta.title}/>
  <meta property="og:description" content={meta.ogDescription || meta.description}/>
  <meta property="og:type"        content="website"/>
  <meta property="og:image"       content="/og-image.png"/>

  <link rel="alternate" hreflang="en" href="https://bakuai.app/"/>
  <link rel="alternate" hreflang="zh" href="https://bakuai.app/zh/"/>
  <link rel="alternate" hreflang="es" href="https://bakuai.app/es/"/>
  <link rel="alternate" hreflang="x-default" href="https://bakuai.app/"/>

  <script type="application/ld+json" set:html={JSON.stringify(ldApp)}/>
  <script type="application/ld+json" set:html={JSON.stringify(ldFaq)}/>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main">
    <slot/>
  </main>
</body>
</html>
