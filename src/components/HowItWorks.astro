---
// src/components/HowItWorks.astro
import type { Lang } from '../lib/i18n';
import { loadContent } from '../lib/i18n';
export interface Props { lang: Lang }
const { lang } = Astro.props;
const c = loadContent(lang, 'how');
// how.yml: eyebrow, sectionTitle, sub, steps: [{n,title,body}]
---
<section id="how" class="px-12" style="padding:100px 48px;">
  <div class="mx-auto" style="max-width:1200px">
    <div class="text-[11px] font-semibold uppercase mb-4 tracking-[0.18em]" style="color:#FFD080">{c.eyebrow}</div>
    <h2 class="font-display font-light m-0 mb-4" style="font-size:58px;line-height:1.05;letter-spacing:-0.02em;color:#E8E0D4">{c.sectionTitle}</h2>
    <p class="text-[19px] m-0 mb-[72px]" style="max-width:640px;color:rgba(232,224,212,.65)">{c.sub}</p>

    <div class="grid grid-cols-3 relative">
      <div class="absolute" style="top:36px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(255,208,128,.3),rgba(255,208,128,.3),transparent);" />
      {c.steps?.map((s: any) => (
        <div class="relative" style="padding:0 24px;">
          <div class="rounded-full flex items-center justify-center font-display font-medium mb-7"
            style="width:72px;height:72px;font-size:22px;color:#FFD080;background:radial-gradient(circle at 35% 35%,#0A0A2A,#050510);border:1px solid rgba(255,208,128,.4);box-shadow:0 0 30px rgba(255,208,128,.15);">
            {s.n}
          </div>
          <h3 class="font-display font-medium m-0 mb-3.5" style="font-size:24px;letter-spacing:-0.01em;color:#E8E0D4">{s.title}</h3>
          <p class="m-0 text-[15px]" style="line-height:1.65;color:rgba(232,224,212,.68)">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
