---
interface Props {
  illustration: string;
  illustrationAlt: string;
  title: string;
  body: string;
}

const { illustration, illustrationAlt, title, body } = Astro.props;
---

<div class="why-card glass-card">
  <img
    src={`/illustrations/${illustration}.png`}
    alt={illustrationAlt}
    class="why-icon"
    width="120"
    height="120"
    loading="lazy"
  />
  <h3 class="why-title">{title}</h3>
  <p class="why-body">{body}</p>
</div>

<style>
  .why-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .why-icon {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 16px;
    filter: drop-shadow(0 0 12px rgba(255, 208, 128, 0.15));
  }

  .why-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    font-variation-settings: "opsz" 48;
    color: var(--color-text-primary);
    margin: 0 0 8px;
  }

  .why-body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }
</style>
